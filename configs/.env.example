# CloudEdgeAgent Environment Variables
# Copy to .env and fill in your values

# App
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Edge LLM (Ollama local)
EDGE_LLM_PROVIDER=ollama
EDGE_LLM_BASE_URL=http://localhost:11434/v1
EDGE_LLM_MODEL_NAME=qwen2.5:7b-instruct
EDGE_LLM_API_KEY=ollama
EDGE_LLM_TEMPERATURE=0.7
EDGE_LLM_MAX_TOKENS=2048

# Cloud LLM (DeepSeek)
CLOUD_LLM_PROVIDER=deepseek
CLOUD_LLM_BASE_URL=https://api.deepseek.com/v1
CLOUD_LLM_MODEL_NAME=deepseek-chat
CLOUD_LLM_API_KEY=sk-your-api-key-here
CLOUD_LLM_TEMPERATURE=0.7
CLOUD_LLM_MAX_TOKENS=4096

# Privacy
PRIVACY_DEFAULT_EPSILON=8.0
PRIVACY_SANITIZE_COST_EPSILON=0.3
PRIVACY_SKETCH_REFINE_COST_EPSILON=1.5
PRIVACY_SLM_MODEL=qwen2.5:1.5b
PRIVACY_ENABLE_NER=true

# Vector Store (Qdrant)
VECTOR_STORE_PROVIDER=qdrant
VECTOR_STORE_HOST=localhost
VECTOR_STORE_PORT=6333
VECTOR_STORE_COLLECTION=agent_memory
